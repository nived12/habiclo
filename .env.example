# Email (Brevo SMTP relay)
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=

# Default sender for transactional emails (password resets, confirmations, receipts).
# Format: "Display Name <email@domain.com>"
TRANSACTIONAL_FROM=Habiclo <noreply@habiclo.com>

# Future: add MARKETING_FROM, SUPPORT_FROM, etc. as new mailer categories ship.

# App
APP_HOST=habiclo.com
