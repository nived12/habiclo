<%= form_with(model: habit, class: "inline-form space-y-5", local: true) do |f| %>
  <% if habit.errors.any? %>
    <div class="marginalia"><span class="note-label"><%= t("marginalia.error") %></span><%= habit.errors.full_messages.to_sentence %></div>
  <% end %>

  <div>
    <%= f.label :name, t("habits.form.name"), class: "field-label" %>
    <%= f.text_field :name, autofocus: true, class: "field-input font-display text-xl", placeholder: "e.g. Zone-2 cardio" %>
  </div>

  <div>
    <%= f.label :description, t("habits.form.description"), class: "field-label" %>
    <%= f.text_area :description, rows: 2, class: "field-input" %>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-2">
    <div>
      <%= f.label :category, t("habits.form.category"), class: "field-label" %>
      <%= f.select :category, Habit::CATEGORIES.map { |c| [t("habits.categories.#{c}"), c] }, {}, class: "field-input" %>
    </div>
    <div>
      <%= f.label :scheduled_at_minute, t("habits.form.time"), class: "field-label" %>
      <% v = params[:habit]&.dig(:scheduled_at_minute) || habit.scheduled_at_minute %>
      <%= f.text_field :scheduled_at_minute, type: :time,
            value: (v ? "%02d:%02d" % [v.to_i / 60, v.to_i % 60] : nil),
            class: "field-input mono" %>
    </div>
    <div>
      <%= f.label :duration_minutes, t("habits.form.duration"), class: "field-label" %>
      <%= f.number_field :duration_minutes, min: 5, step: 5, class: "field-input mono" %>
    </div>
  </div>

  <%= render "habits/frequency_section", f: f, habit: habit %>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
    <div>
      <%= f.label :target_value, t("habits.form.target"), class: "field-label" %>
      <%= f.number_field :target_value, step: 0.5, class: "field-input mono" %>
    </div>
    <div>
      <%= f.label :unit, t("habits.form.unit"), class: "field-label" %>
      <%= f.text_field :unit, class: "field-input" %>
    </div>
    <div>
      <%= f.label :color_hue, t("habits.form.color"), class: "field-label" %>
      <div class="flex items-center gap-3 color-hue-group">
        <span class="hue-swatch w-6 h-6 rounded-full flex-shrink-0 border border-[var(--color-hairline)]"
              style="background: oklch(58% 0.16 <%= habit.color_hue %>);"></span>
        <%= f.range_field :color_hue, min: 0, max: 360, step: 1, class: "flex-1",
              oninput: "var g=this.closest('.color-hue-group');g.querySelector('.hue-swatch').style.background=`oklch(58% 0.16 ${this.value})`;g.querySelector('.hue-label').textContent=this.value" %>
        <span class="hue-label mono text-xs text-[var(--color-ink-muted)] w-10 text-right"><%= habit.color_hue %></span>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-3">
    <%= link_to t("habits.form.cancel"), root_path, class: "almanac-button almanac-button--ghost text-xs" %>
    <%= f.submit t("habits.form.save"), class: "almanac-button text-xs" %>
  </div>
<% end %>
