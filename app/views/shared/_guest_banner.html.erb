<%
  user = current_or_guest_user
  days = user&.days_until_reset
  hours = user&.hours_until_reset
  message_key =
    if days.nil?
      "guest_banner.example_today"
    elsif days == 0 && hours && hours <= 24
      hours <= 0 ? "guest_banner.example_today" : "guest_banner.example_hours"
    elsif days == 1
      "guest_banner.example_one"
    else
      "guest_banner.example"
    end
  urgency_class =
    if days.nil? || days <= 0 then "is-urgent"
    elsif days <= 2 then "is-warning"
    else ""
    end
%>
<div class="guest-banner <%= urgency_class %>">
  <span class="guest-banner-message">
    <em><%= t(message_key, count: days || hours || 0) %></em>
  </span>
  <span class="guest-banner-actions mono">
    <%= link_to t("guest_banner.save_progress"), new_user_registration_path,
          class: "guest-banner-cta underline decoration-1 underline-offset-4 hover:text-[var(--color-accent)]" %>
    <%= link_to t("guest_banner.change_template"), templates_path,
          class: "guest-banner-link" %>
    <%= button_to t("guest_banner.fresh_start"), guest_fresh_start_path,
          method: :post,
          class: "guest-banner-link guest-banner-link--button",
          data: { turbo_confirm: t("guest_banner.confirm_fresh_start") } %>
    <%= button_to t("guest_banner.reset_now"), guest_reset_path,
          method: :post,
          class: "guest-banner-link guest-banner-link--button",
          data: { turbo_confirm: t("guest_banner.confirm_reset") } %>
  </span>
</div>
