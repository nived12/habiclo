<%#
  Password input with a show/hide eye toggle.
  Locals: f (form builder), field (symbol), autocomplete (string)
%>
<div data-controller="password-visibility" class="relative">
  <%= f.password_field field, autocomplete: autocomplete,
        class: "field-input pr-8",
        data: { "password-visibility-target": "input" } %>
  <button type="button" tabindex="-1"
          data-action="password-visibility#toggle"
          aria-label="<%= t("devise.toggle_password") %>"
          class="absolute right-0 bottom-2 text-[var(--color-ink-muted)] hover:text-[var(--color-accent)]">
    <svg data-password-visibility-target="show" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
    </svg>
    <svg data-password-visibility-target="hide" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9.9 4.24A9.1 9.1 0 0 1 12 4c6.5 0 10 7 10 7a13.2 13.2 0 0 1-1.67 2.68"/><path d="M6.06 6.06A13.2 13.2 0 0 0 2 11s3.5 7 10 7a9.1 9.1 0 0 0 4.94-1.06"/><path d="m1 1 22 22"/><path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/>
    </svg>
  </button>
</div>
