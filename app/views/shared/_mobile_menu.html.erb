<div id="mobile_menu" class="mobile-menu">
  <div class="mobile-menu-shroud" data-action="click->mobile-menu#closeOnBackdrop"></div>
  <nav class="mobile-menu-panel" aria-label="<%= t('nav.menu') %>">
    <header class="mobile-menu-header">
      <p class="almanac-eyebrow mb-0"><%= t("app.name") %></p>
      <% if user_signed_in? %>
        <div class="mobile-menu-user">
          <span class="user-monogram"><%= current_user.display_name.first.upcase %></span>
          <span class="mono text-sm"><%= current_user.display_name %></span>
        </div>
      <% end %>
    </header>
    <ul class="mobile-menu-links">
      <li>
        <%= link_to health_path, class: "mobile-menu-link", data: { action: "click->mobile-menu#close" } do %>
          <span><%= t("nav.health") %></span>
          <span class="mono text-xs text-[var(--color-ink-muted)]">→</span>
        <% end %>
      </li>
      <li>
        <%= link_to settings_path, class: "mobile-menu-link", data: { action: "click->mobile-menu#close" } do %>
          <span><%= t("nav.settings") %></span>
          <span class="mono text-xs text-[var(--color-ink-muted)]">→</span>
        <% end %>
      </li>
      <li>
        <button type="button"
                class="mobile-menu-link mobile-menu-link--button"
                data-action="click->mobile-menu#close click->help#open">
          <span><%= t("nav.help") %></span>
          <span class="mono text-xs text-[var(--color-ink-muted)]">?</span>
        </button>
      </li>
      <% if owner_view? %>
        <li>
          <%= link_to admin_metrics_path, class: "mobile-menu-link", data: { action: "click->mobile-menu#close" } do %>
            <span>Metrics</span>
            <span class="mono text-xs text-[var(--color-ink-muted)]">→</span>
          <% end %>
        </li>
      <% end %>
    </ul>
    <footer class="mobile-menu-footer">
      <% if user_signed_in? %>
        <%= button_to t("nav.sign_out"), destroy_user_session_path, method: :delete,
              class: "almanac-button almanac-button--ghost w-full text-xs" %>
      <% else %>
        <%= link_to t("nav.sign_in"), new_user_session_path,
              class: "almanac-button w-full text-xs text-center",
              data: { action: "click->mobile-menu#close" } %>
      <% end %>
    </footer>
  </nav>
</div>
