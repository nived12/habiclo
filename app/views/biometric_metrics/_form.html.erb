<% return_to = local_assigns[:return_to] %>
<div class="health-modal-shroud" data-action="click->modal-close#close">
  <div class="health-modal-panel" data-action="click->modal-close#stopPropagation" role="dialog">
    <p class="health-modal-title">
      <%= metric.persisted? ? t("health.biometrics.metric_form.save_edit") : t("health.biometrics.metric_form.save") %>
    </p>

    <%= form_with(model: metric,
          url: metric.persisted? ? biometric_metric_path(metric) : biometric_metrics_path,
          method: metric.persisted? ? :patch : :post,
          class: "space-y-4") do |f| %>
      <%= hidden_field_tag :return_to, return_to if return_to.present? %>
      <%= render "biometric_metrics/form_fields", f: f, metric: metric %>
    <% end %>
  </div>
</div>
