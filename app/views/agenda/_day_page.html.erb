<% scheduled = entries.reject(&:floating?) %>
<% floating  = entries.select(&:floating?) %>
<% ratio = completion_ratio_for(entries) %>

<div class="day-page">
  <header class="day-page-header">
    <p class="almanac-eyebrow">
      <% if on_date == today %>
        <%= t("agenda.today_eyebrow") %>
      <% else %>
        <% diff = (on_date - today).to_i %>
        <%= diff > 0 ? t("agenda.in_days", n: diff) : t("agenda.days_ago", n: -diff) %>
      <% end %>
    </p>
    <h2 class="day-page-date">
      <span class="mono day-num"><%= on_date.day.to_s.rjust(2, "0") %></span>
      <span class="day-month"><%= l(on_date, format: "%B").mb_chars.capitalize %></span>
    </h2>
    <p class="day-weekday"><%= l(on_date, format: "%A").mb_chars.capitalize %></p>

    <% if ratio %>
      <div class="day-page-ratio mt-3">
        <div class="day-ratio-bar"><div class="day-ratio-fill" style="width: <%= ratio[:pct] %>%;"></div></div>
        <span class="mono text-xs ml-2"><%= ratio[:completed] %> / <%= ratio[:total] %> · <%= ratio[:pct] %>%</span>
      </div>
    <% end %>
  </header>

  <% if floating.any? %>
    <section class="day-section">
      <p class="almanac-eyebrow"><%= t("agenda.floating") %></p>
      <div class="floating-rail mt-2">
        <% floating.each do |entry| %>
          <%= render "agenda/floating_chip", entry: entry, on_date: on_date %>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="day-section">
    <p class="almanac-eyebrow"><%= t("agenda.schedule") %></p>
    <% if scheduled.empty? %>
      <p class="text-[var(--color-ink-muted)] italic text-sm mt-2"><%= t("agenda.empty", shortcut: "n") %></p>
    <% else %>
      <ol class="day-timeline mt-2">
        <% scheduled.each do |entry| %>
          <li class="day-timeline-row">
            <span class="mono day-timeline-time">
              <% if entry.scheduled_at_minute %>
                <%= "%02d:%02d" % [entry.scheduled_at_minute / 60, entry.scheduled_at_minute % 60] %>
              <% else %>
                —
              <% end %>
            </span>
            <span class="day-timeline-rule" style="--block-hue: <%= entry.color_hue %>;"></span>
            <%= render "agenda/block", entry: entry, on_date: on_date, compact: false,
                  all_completions_map: local_assigns[:all_completions_map],
                  completions_map: local_assigns[:completions_map] %>
          </li>
        <% end %>
      </ol>
    <% end %>
  </section>

  <section class="day-section">
    <p class="almanac-eyebrow"><%= t("agenda.margin_notes") %></p>
    <p class="text-[var(--color-ink-muted)] text-sm mt-2 italic">
      <%= t("marginalia.strength_explainer") %>
    </p>
  </section>
</div>
