<% content_for :title, t("devise.sign_in_submit") %>

<section class="max-w-md mx-auto py-8">
  <p class="almanac-eyebrow"><%= t("app.name") %></p>
  <h1 class="display-lg mb-8" style="font-style: italic;"><%= t("devise.sign_in_title") %></h1>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <div>
      <%= f.label :email, class: "field-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "field-input" %>
    </div>
    <div>
      <div class="flex items-baseline justify-between">
        <%= f.label :password, class: "field-label" %>
        <%= link_to t("devise.forgot_password"), new_user_password_path, class: "text-xs text-[var(--color-ink-muted)] underline decoration-1 underline-offset-4 hover:text-[var(--color-accent)]" %>
      </div>
      <%= f.password_field :password, autocomplete: "current-password", class: "field-input" %>
    </div>
    <%= f.submit t("devise.sign_in_submit"), class: "almanac-button w-full justify-center" %>
  <% end %>

  <p class="mt-6 text-sm text-[var(--color-ink-muted)] text-center">
    <%= link_to t("devise.sign_in_link"), new_user_registration_path, class: "underline decoration-1 underline-offset-4" %>
  </p>
</section>
