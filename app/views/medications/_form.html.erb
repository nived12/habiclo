<%= form_with(model: medication, url: medication.new_record? ? medications_path : medication_path(medication),
               method: medication.new_record? ? :post : :patch,
               class: "space-y-4") do |f| %>
  <%= hidden_field_tag :return_to, @return_to if @return_to.present? %>
  <% if medication.errors.any? %>
    <div class="marginalia">
      <span class="note-label"><%= t("marginalia.error") %></span>
      <%= medication.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, t("health.medications.form.name"), class: "field-label" %>
    <%= f.text_field :name, class: "field-input", autofocus: true %>
  </div>
  <div>
    <%= f.label :dose, t("health.medications.form.dose"), class: "field-label" %>
    <%= f.text_field :dose, class: "field-input mono", placeholder: "p. ej. 150/5 mg" %>
  </div>
  <div>
    <label class="field-label"><%= t("health.medications.form.schedule") %></label>
    <div class="space-y-2" id="schedule-times">
      <% (medication.schedule_minutes.presence || [nil]).each_with_index do |minute, i| %>
        <input type="time" name="medication[schedule_minutes][]"
               value="<%= minute ? '%02d:%02d' % [minute / 60, minute % 60] : '' %>"
               class="field-input mono w-36">
      <% end %>
    </div>
    <button type="button" class="mono text-xs text-[var(--color-accent)] mt-2 hover:underline"
            onclick="const c=document.getElementById('schedule-times'); const inp=document.createElement('input'); inp.type='time'; inp.name='medication[schedule_minutes][]'; inp.className='field-input mono w-36 block mt-2'; c.appendChild(inp)">
      + <%= t("health.medications.form.add_time") %>
    </button>
  </div>
  <div>
    <%= f.label :notes, t("health.medications.form.notes"), class: "field-label" %>
    <%= f.text_area :notes, rows: 2, class: "field-input" %>
  </div>
  <div class="flex gap-3">
    <%= f.submit (medication.new_record? ? t("health.medications.form.save") : t("habits.form.save")),
          class: "almanac-button text-xs" %>
    <%= link_to t("habits.form.cancel"), (@return_to.presence || health_path), class: "almanac-button almanac-button--ghost text-xs" %>
  </div>
<% end %>
