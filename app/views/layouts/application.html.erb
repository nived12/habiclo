<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= t("app.tagline") %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preload" href="/fonts/Fraunces.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/IBMPlexSans-Regular.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/IBMPlexMono-Regular.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <style>:root { --brand-hue: <%= (current_or_guest_user&.brand_hue || 25) %>; }</style>
  </head>

  <body data-controller="keyboard-nav brand-hue help" data-help-seen-value="<%= cookies[:habiclo_help_seen] == '1' %>">
    <%= render "shared/topbar" %>
    <%= render "shared/guest_banner" if current_or_guest_user&.guest? %>

    <main class="almanac-page">
      <%= yield %>
    </main>

    <%= turbo_frame_tag "log_modal" %>
    <%= render "shared/help_panel" %>
  </body>
</html>
