<% content_for :title, t("settings.title") %>

<section class="almanac-header">
  <div>
    <p class="almanac-eyebrow"><%= t("settings.title") %></p>
    <h1 class="display-lg"><%= t("settings.title") %></h1>
  </div>
</section>

<div class="mt-6 grid lg:grid-cols-12 gap-8">
  <%= form_with(model: @user, url: settings_path, method: :patch, class: "lg:col-span-8 space-y-8") do |f| %>
    <div>
      <label class="field-label"><%= t("settings.email") %></label>
      <p class="field-input" style="background: var(--color-paper-deep); color: var(--color-ink-muted); cursor: default;"><%= @user.email %></p>
      <p class="field-hint mt-1"><%= t("settings.email_hint") %></p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <%= f.label :first_name, class: "field-label" %>
        <%= f.text_field :first_name, autocomplete: "given-name", class: "field-input" %>
      </div>
      <div>
        <%= f.label :last_name, class: "field-label" %>
        <%= f.text_field :last_name, autocomplete: "family-name", class: "field-input" %>
      </div>
    </div>
    <div>
      <%= f.label :username, t("settings.username"), class: "field-label" %>
      <%= f.text_field :username, class: "field-input",
            placeholder: t("settings.username_placeholder") %>
      <p class="field-hint mt-1"><%= t("settings.username_hint") %></p>
    </div>
    <div data-controller="brand-hue" data-brand-hue-url-value="<%= settings_path %>">
      <%= render "shared/color_swatch_picker",
            name: "user[brand_hue]",
            value: @user.brand_hue,
            label: t("settings.accent_color") %>
      <p class="field-hint mt-2"><%= t("settings.accent_color_hint") %></p>
    </div>

    <div class="grid md:grid-cols-2 gap-6"
         data-controller="tz-detect">
      <div>
        <label class="field-label"><%= t("settings.time_zone") %></label>
        <%= f.time_zone_select :time_zone,
              ActiveSupport::TimeZone.all,
              { default: @user.time_zone.presence || @detected_time_zone },
              class: "field-input" %>
        <p class="field-hint mt-1"><%= t("settings.time_zone_hint") %></p>
      </div>
      <div>
        <label class="field-label"><%= t("settings.locale") %></label>
        <%= f.select :locale, [["English", "en"], ["Español (MX)", "es"]], {}, class: "field-input" %>
      </div>
    </div>

    <div>
      <label class="field-label"><%= t("settings.optional_sections") %></label>
      <p class="field-hint mb-3"><%= t("settings.optional_sections_hint") %></p>
      <div class="space-y-2">
        <% %w[medications labs biometrics].each do |tab| %>
          <label class="config-tab-row" style="cursor: pointer;">
            <%= hidden_field_tag "user[tabs_visibility][#{tab}]", "false", id: nil %>
            <%= check_box_tag "user[tabs_visibility][#{tab}]", "true", @user.tab_visible?(tab), class: "mt-1" %>
            <div class="config-tab-info">
              <div class="config-tab-name"><%= t("settings.sections.#{tab}") %></div>
              <div class="config-tab-desc"><%= t("settings.sections.#{tab}_desc") %></div>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <%= f.submit t("habits.form.save"), class: "almanac-button text-xs" %>
  <% end %>
</div>
