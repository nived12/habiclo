#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the rails server then create or migrate existing database.
# IMPORTANT (deploy gotcha): this block ONLY fires when the command ends in
# exactly `./bin/rails server` (the Dockerfile's default CMD, served via
# Thruster). Do NOT set a Railway "Custom Start Command" / railway.json
# startCommand — it both fails this condition (so migrations never run) and
# bypasses Thruster, leaving the container up with no Rails process (502).
# New migrations (Ahoy, etc.) apply automatically here on deploy.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare

  # Solid Queue/Cache/Cable store their tables in the primary's physical DB, but
  # db:prepare skips loading their schema files because it sees the (shared)
  # database already exists. Load each schema file directly when its tables are
  # missing — idempotent, and never wipes existing job/cache data. We load the
  # file rather than `db:schema:load:<db>` because that rake task pulls in
  # db:test:purge + the protected-environment guard, which aborts in production.
  for pair in "queue:solid_queue_jobs" "cache:solid_cache_entries" "cable:solid_cable_messages"; do
    db="${pair%%:*}"; table="${pair##*:}"
    if ! ./bin/rails runner "exit(ActiveRecord::Base.connection.table_exists?('${table}') ? 0 : 1)"; then
      echo "[entrypoint] Loading ${db} schema (${table} missing)"
      ./bin/rails runner "ActiveRecord::Base.establish_connection(:${db}); load Rails.root.join('db', '${db}_schema.rb')"
    fi
  done
fi

exec "${@}"
